{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and every additional workspace-* window opened via File > New Window or the macOS Dock reopen path",
  "windows": ["main", "workspace-*"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "fs:default",
    "fs:allow-watch",
    "store:default",
    "updater:default",
    "process:default"
  ]
}
