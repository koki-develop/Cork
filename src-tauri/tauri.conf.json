{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cork",
  "version": "../package.json",
  "identifier": "me.koki.cork",
  "build": {
    "beforeDevCommand": "bun run build:sidecar && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:sidecar && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/cork-cli"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns"],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/koki-develop/Cork/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZBMTU4Q0NFN0QyMTcwOEQKUldTTmNDRjl6b3dWK2hNdG1TQ1M5MVUvUEQ3YXVUS3VkTllCUVg1RlhuSDZKV2JwaTJxclpCQloK"
    }
  }
}
